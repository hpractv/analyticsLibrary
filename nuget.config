<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Central package management (NU1507) requires either a single feed or explicit
    package source mapping when multiple feeds exist. This repo only restores
    public packages from nuget.org, so we isolate the solution from other machine-wide feeds.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
